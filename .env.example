# Copy to .env for local dev. In production these are set in the Vercel
# project's Environment Variables (VITE_* values are PUBLIC — inlined at build).

# Base URL of the Oriventra backend API (include the /api/v1 path).
# Local:  http://localhost:8000/api/v1
# Prod:   https://your-backend-domain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Stripe publishable key (test or live). Publishable keys are safe to expose.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
